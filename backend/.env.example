SECRET_KEY="change_me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DB can be PostgreSQL or TiDB/MySQL
# PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/iqmath"
# TiDB/MySQL:
# DATABASE_URL="mysql://user:password@gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com:4000/test?ssl_verify_cert=true&ssl_verify_identity=true"
DATABASE_URL="mysql://user:password@host:4000/test?ssl_verify_cert=true&ssl_verify_identity=true"
DB_SSL_CA_PATH="E:/path/to/isrgrootx2.pem"

RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
GEMINI_API_KEY="your_gemini_api_key"
EMAIL_SENDER="your_email@example.com"
BREVO_API_KEY="your_brevo_api_key"
# --- Code execution (compiler) ---
# Free default: omit AWS_LAMBDA_URL (or set CODE_EXECUTION_BACKEND=local) to run Python on
# this server and C++/Java via Judge0 CE (JUDGE0_API_URL) or local g++/javac if installed.
# CODE_EXECUTION_BACKEND=auto   # use Lambda only when AWS_LAMBDA_URL is set (default)
# CODE_EXECUTION_BACKEND=local
# CODE_EXECUTION_BACKEND=lambda   # requires AWS_LAMBDA_URL
# AWS_LAMBDA_URL="https://your.lambda-url.on.aws/"
# JUDGE0_API_URL=https://ce.judge0.com
# Optional RapidAPI Judge0 (host + key) instead of public CE:
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
# JUDGE0_RAPIDAPI_KEY=
